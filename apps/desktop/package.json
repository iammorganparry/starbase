{
  "name": "@starbase/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Starbase — an agent-session manager for coding CLIs.",
  "main": "./out/main/index.js",
  "author": {
    "name": "Morgan Parry",
    "email": "morgan@trigify.io"
  },
  "homepage": "https://github.com/iammorganparry/starbase",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:fast": "SKIP_E2E_BUILD=1 playwright test",
    "e2e:report": "playwright show-report",
    "dist": "electron-vite build && electron-builder --dir",
    "electron:pack": "electron-vite build && electron-builder",
    "electron:publish": "electron-vite build && electron-builder --publish always",
    "clean": "rimraf out dist release .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@effect/rpc": "^0.75.1",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@openai/codex-sdk": "^0.144.1",
    "@tanstack/react-query": "^5.101.2",
    "@xstate/react": "^6.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "effect": "^3.21.4",
    "electron-updater": "^6.3.9",
    "xstate": "^5.32.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@starbase/cli-adapters": "workspace:*",
    "@starbase/contracts": "workspace:*",
    "@starbase/core": "workspace:*",
    "@starbase/tsconfig": "workspace:*",
    "@starbase/ui": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "43.1.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "playwright": "^1.61.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.6"
  }
}
