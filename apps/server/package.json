{
  "name": "@starbase/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Starbase auth backend — BetterAuth over Postgres/Drizzle, hosted on Hono (local + Vercel).",
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "STARBASE_DB_TESTS=1 vitest run --config vitest.integration.config.ts",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.4",
    "hono": "^4.12.30",
    "postgres": "^3.4.9",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "@starbase/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.31.10",
    "rimraf": "^6.0.1",
    "tsx": "^4.23.1",
    "vitest": "^3.2.6"
  }
}
