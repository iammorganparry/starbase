# ── @starbase/server — auth backend ──────────────────────────────────────────
# Copy to .env for local dev. Dev works with ZERO real secrets: Docker Postgres
# + console magic links. OAuth + real email only needed to exercise those paths.

NODE_ENV=development
PORT=9100

# Local Docker Postgres (see root docker-compose.yml). In prod point this at a
# managed Postgres behind a transaction-mode pooler (Supabase/Neon/PgBouncer).
DATABASE_URL=postgres://postgres:postgres@localhost:5433/starbase

# BetterAuth. MUST be a strong random value in production (e.g. `openssl rand -hex 32`).
BETTER_AUTH_SECRET=dev-insecure-secret-change-me
BETTER_AUTH_URL=http://localhost:9100

# Deep link the desktop app registers. OAuth/magic-link bounce back here.
DESKTOP_REDIRECT=starbase://auth/callback

# GitHub OAuth app → Authorization callback URL: http://localhost:9100/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth client → Authorized redirect URI: http://localhost:9100/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (magic-link email in prod). Leave blank in dev to log links to the console.
RESEND_API_KEY=
EMAIL_FROM=Starbase <login@starbase.local>
